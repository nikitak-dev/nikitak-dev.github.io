---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>
  <div id="boot-screen">
    <div id="boot-lines"></div>
    <div id="boot-skip">// click or press any key to skip</div>
  </div>

  <main id="hub">
    <div class="grid-legend">
      <span class="legend-item legend-ai"><span class="legend-dot"></span>AI-POWERED</span>
      <span class="legend-item legend-auto"><span class="legend-dot"></span>AUTOMATION</span>
    </div>
    <div class="project-grid">

      <!-- [ 001 ] VOICE_AGENT -->
      <div class="project-card" data-index="1" data-url="#">
        <div class="card-header">
          <span class="card-id">[ 001 ]</span>
          <span class="card-status private">○ PRIVATE</span>
        </div>
        <div class="card-body">
          <h2 class="card-title">VOICE_AGENT</h2>
          <p class="card-desc">Never miss a lead because no one picked up the phone. An AI agent handles inbound calls 24/7 — qualifies prospects, schedules meetings and logs key metrics to a database automatically. Built on voice AI infrastructure.</p>
          <div class="card-stack">
            <span class="stack-comment">// VAPI | n8n | Airtable | Google Calendar</span>
          </div>
        </div>
        <div class="card-footer">
          <span class="card-meta">For companies paying humans to answer routine calls</span>
          <button class="card-launch btn-terminal" disabled aria-label="Contact about VOICE_AGENT project">[ CONTACT ]</button>
        </div>
      </div>

      <!-- [ 002 ] MULTIMODAL_RAG -->
      <div class="project-card" data-index="2" data-url="/multimodal-rag/">
        <div class="card-header">
          <span class="card-id">[ 002 ]</span>
          <span class="card-status live">● LIVE</span>
        </div>
        <div class="card-body">
          <h2 class="card-title">MULTIMODAL_RAG</h2>
          <p class="card-desc">What if you could Google your own files? Upload anything — docs, images, audio, video, PDFs — ask in plain language, get the answer. Built on vector embeddings and semantic retrieval.</p>
          <div class="card-stack">
            <span class="stack-comment">// n8n | Gemini | Pinecone | OpenRouter</span>
          </div>
        </div>
        <div class="card-footer">
          <span class="card-meta">For teams where "find the document" wastes hours</span>
          <button class="card-launch btn-terminal" aria-label="Launch MULTIMODAL_RAG demo">[ LAUNCH ]</button>
        </div>
      </div>

      <!-- [ 003 ] COMING SOON -->
      <div class="project-card theme-red" data-index="3">
        <div class="card-header">
          <span class="card-id">[ 003 ]</span>
          <span class="card-status wip">○ WIP</span>
        </div>
        <div class="card-body">
          <h2 class="card-title">COMING_SOON</h2>
          <p class="card-desc">Next project in development.</p>
          <div class="card-stack"></div>
        </div>
        <div class="card-footer">
          <span class="card-meta">—</span>
          <button class="card-launch btn-terminal" disabled>[ LOCKED ]</button>
        </div>
      </div>

      <!-- [ 004 ] COMING SOON -->
      <div class="project-card theme-red" data-index="4">
        <div class="card-header">
          <span class="card-id">[ 004 ]</span>
          <span class="card-status wip">○ WIP</span>
        </div>
        <div class="card-body">
          <h2 class="card-title">COMING_SOON</h2>
          <p class="card-desc">Next project in development.</p>
          <div class="card-stack"></div>
        </div>
        <div class="card-footer">
          <span class="card-meta">—</span>
          <button class="card-launch btn-terminal" disabled>[ LOCKED ]</button>
        </div>
      </div>

    </div>
  </main>

  <script is:inline>
    /* --- Boot sequence --- */
    const bootScreen = document.getElementById('boot-screen');
    const bootLinesEl = document.getElementById('boot-lines');
    const grid = document.querySelector('.project-grid');

    const bootSequence = [
      { text: 'INIT 0x00 :: ENTROPY POOL... [OK]',          bright: false },
      { text: 'MAPPING 0x7FFE4B2A -- 0x00C3F190 [DONE]',    bright: false },
      { text: 'PROC 1024 :: HEAP ALLOC 4096B',               bright: false },
      { text: 'CRC32 A4D3F9B1 -- INTEGRITY VALID',           bright: false },
      { text: '> BOOT COMPLETE',                              bright: true  },
    ];

    let bootDone = false;

    function endBoot() {
      if (bootDone) return;
      bootDone = true;
      bootScreen.classList.add('done');
      grid.classList.add('ready');
    }

    function runBoot() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        bootSequence.forEach(line => {
          const el = document.createElement('div');
          el.className = 'boot-line' + (line.bright ? ' bright' : '');
          el.textContent = line.text;
          bootLinesEl.appendChild(el);
        });
        endBoot();
        return;
      }
      let i = 0;
      function addLine() {
        if (bootDone) return;
        if (i >= bootSequence.length) { setTimeout(endBoot, 1500); return; }
        const el = document.createElement('div');
        el.className = 'boot-line' + (bootSequence[i].bright ? ' bright' : '');
        bootLinesEl.appendChild(el);
        const text = bootSequence[i].text;
        i++;
        const textNode = document.createTextNode('');
        const cursorSpan = document.createElement('span');
        cursorSpan.className = 'boot-cursor';
        cursorSpan.textContent = '|';
        el.appendChild(textNode);
        el.appendChild(cursorSpan);
        let c = 0;
        const type = setInterval(() => {
          if (bootDone) { clearInterval(type); cursorSpan.remove(); return; }
          textNode.textContent = text.slice(0, ++c);
          if (c >= text.length) {
            clearInterval(type);
            if (i >= bootSequence.length) {
              cursorSpan.classList.add('blinking');
              setTimeout(addLine, 200);
            } else {
              cursorSpan.remove();
              setTimeout(addLine, 200);
            }
          }
        }, 25);
      }
      addLine();
    }

    runBoot();
    bootScreen.addEventListener('click', endBoot);
    document.addEventListener('keydown', endBoot, { once: true });

    /* --- Card selection & keyboard navigation --- */
    const cards = document.querySelectorAll('.project-card');
    let selectedCard = null;

    function selectCard(card) {
      if (selectedCard) selectedCard.classList.remove('selected');
      selectedCard = card || null;
      if (selectedCard) selectedCard.classList.add('selected');
    }

    function launchSelected() {
      if (!selectedCard) return;
      const btn = selectedCard.querySelector('.card-launch');
      if (btn && btn.disabled) return;
      const url = selectedCard.dataset.url;
      if (url && url !== '#') window.location.href = url;
    }

    cards.forEach(card => {
      card.addEventListener('click', e => {
        selectCard(card);
        if (e.target.closest('.card-launch')) launchSelected();
      });
    });

    document.addEventListener('click', e => {
      if (!e.target.closest('.project-card')) selectCard(null);
    });

    document.addEventListener('keydown', e => {
      if (!bootDone) return;
      if (['1', '2', '3', '4'].includes(e.key)) {
        const idx = parseInt(e.key) - 1;
        if (cards[idx]) selectCard(cards[idx]);
      } else if (e.key === 'Enter') {
        launchSelected();
      } else if (e.key === 'Escape') {
        selectCard(null);
      }
    });
  </script>
</BaseLayout>