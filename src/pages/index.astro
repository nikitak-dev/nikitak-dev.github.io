---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocsModal from '../components/DocsModal.astro';
import VoiceAgentDocs from '../components/docs/VoiceAgentDocs.astro';
import DbMergeDocs from '../components/docs/DbMergeDocs.astro';
import FolderCloneDocs from '../components/docs/FolderCloneDocs.astro';
import { PROJECTS, publicCount, totalCount, categoryCount, STATUS_LABEL } from '../data/projects';
import '../styles/intro.css';

const pub = publicCount();
const total = totalCount();
const aiCount = categoryCount('ai');
const autoCount = categoryCount('automation');
---
<BaseLayout procPublic={pub} procTotal={total}>
  <script is:inline>
    try { if (localStorage.getItem('intro-seen')) document.documentElement.dataset.introSeen = '1'; } catch (e) {}
  </script>

  <div id="intro-screen" role="dialog" aria-modal="true" aria-labelledby="intro-title">
    <div class="intro-panel">
      <div class="intro-header"><span id="intro-title" class="section-label">// INTRO</span></div>
      <div class="intro-divider intro-divider--head"><span class="intro-glow"></span></div>
      <div class="intro-body">
        <p class="intro-line"><span class="intro-prompt">&gt;</span> <span class="intro-text">hi — this is the automation portfolio of Nikita Kurdybailo.</span></p>
        <p class="intro-line"><span class="intro-prompt">&gt;</span> <span class="intro-text">each card below is a project. open one to read what it does — or, where it's public, try it yourself.</span></p>
        <p class="intro-line" data-html="up top: github <span class='intro-sep'>|</span> linkedin <span class='intro-sep'>|</span> telegram — to reach me."><span class="intro-prompt">&gt;</span> <span class="intro-text">up top: github | linkedin | telegram — to reach me.</span></p>
      </div>
      <div class="intro-divider intro-divider--foot"><span class="intro-glow"></span></div>
      <div class="intro-foot">
        <span class="intro-role">// AI automation &amp; integration</span>
        <button type="button" class="intro-enter btn-terminal">Enter hub</button>
      </div>
    </div>
  </div>

  <main id="hub">
   <div class="hub-content" data-cascade-item>
    <div class="grid-legend">
      <span class="section-label">// LEGEND:</span>
      <span class="legend-item legend-ai"><span class="legend-dot"></span>AI-POWERED <span class="legend-count">[{aiCount}]</span></span>
      <span class="legend-item legend-auto"><span class="legend-dot"></span>AUTOMATION <span class="legend-count">[{autoCount}]</span></span>
      <button
        type="button"
        id="intro-trigger"
        class="btn-terminal legend-help"
        aria-haspopup="dialog"
        aria-controls="intro-screen"
      >INTRO</button>
    </div>
    <div class="project-grid">
      {PROJECTS.map((p, i) => {
        const isPage = p.action === 'page';
        const CardTag = isPage ? 'a' : 'div';
        const route = `/${p.slug}/`;
        return (
          <CardTag
            class={`project-card${p.category === 'automation' ? ' theme-amber' : ''}`}
            data-index={i + 1}
            data-url={isPage ? route : undefined}
            href={isPage ? route : undefined}
          >
            <div class="card-header">
              <span class="card-id">[ {p.id} ]</span>
              <span class={`card-status ${p.status}`}>{STATUS_LABEL[p.status]}</span>
            </div>
            <div class="card-body">
              <h2 class="card-title">{p.title}</h2>
              <p class="card-desc">{p.desc}</p>
              <div class="card-stack">
                {p.stack && <span class="stack-comment">// {p.stack}</span>}
              </div>
            </div>
            <div class="card-footer">
              <span class="card-meta">{p.meta}</span>
              {isPage ? (
                <span class="card-launch btn-terminal" aria-hidden="true">{p.button.label}</span>
              ) : (
                <button
                  class="card-launch btn-terminal"
                  disabled={p.button.disabled}
                  aria-haspopup="dialog"
                  aria-controls={`${p.slug}-about`}
                  aria-expanded="false"
                  aria-label={p.button.ariaLabel}
                >{p.button.label}</button>
              )}
            </div>
          </CardTag>
        );
      })}
    </div>
   </div>
  </main>

  {/* In-place ABOUT modals for projects without a dedicated page (action: 'about').
      Opened from their card via aria-controls. MULTIMODAL_RAG keeps its page (action: 'page'). */}
  <DocsModal id="voice-agent-about" title="VOICE_AGENT :: ABOUT">
    <VoiceAgentDocs slot="overview" />
  </DocsModal>
  <DocsModal id="db-merge-about" title="DB_MERGE :: ABOUT" theme="amber">
    <DbMergeDocs slot="overview" />
  </DocsModal>
  <DocsModal id="folder-clone-about" title="FOLDER_CLONE :: ABOUT" theme="amber">
    <FolderCloneDocs slot="overview" />
  </DocsModal>

  <script>import '../scripts/hub';</script>
</BaseLayout>