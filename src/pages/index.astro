---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocsModal from '../components/DocsModal.astro';
import { PROJECTS, liveCount, totalCount, categoryCount, STATUS_SYMBOL, STATUS_LABEL } from '../data/projects';

const live = liveCount();
const total = totalCount();
const aiCount = categoryCount('ai');
const autoCount = categoryCount('automation');
const buildDate = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Berlin' });
---
<BaseLayout procLive={live} procTotal={total}>
  <div id="boot-screen">
    <div id="boot-lines"></div>
    <div id="boot-skip">// click or press any key to skip</div>
  </div>

  <main id="hub">
    <div class="grid-legend" data-cascade-item>
      <span class="section-label">// LEGEND:</span>
      <span class="legend-item legend-ai"><span class="legend-dot"></span>AI-POWERED <span class="legend-count">[{aiCount}]</span></span>
      <span class="legend-item legend-auto"><span class="legend-dot"></span>AUTOMATION <span class="legend-count">[{autoCount}]</span></span>
      <button
        type="button"
        id="shortcuts-trigger"
        class="btn-terminal legend-help"
        aria-haspopup="dialog"
        aria-controls="shortcuts-modal"
        aria-expanded="false"
      >SHORTCUTS</button>
    </div>
    <div class="project-grid" data-cascade-item>
      {PROJECTS.map((p, i) => {
        const CardTag = p.url ? 'a' : 'div';
        return (
          <CardTag
            class={`project-card${p.category === 'automation' ? ' theme-amber' : ''}`}
            data-index={i + 1}
            data-url={p.url ?? '#'}
            href={p.url}
          >
            <div class="card-header">
              <span class="card-id">[ {p.id} ]</span>
              <span class={`card-status ${p.status}`}>{STATUS_SYMBOL[p.status]} {STATUS_LABEL[p.status]}</span>
            </div>
            <div class="card-body">
              <h2 class="card-title">{p.title}</h2>
              <p class="card-desc">{p.desc}</p>
              <div class="card-stack">
                {p.stack && <span class="stack-comment">// {p.stack}</span>}
              </div>
            </div>
            <div class="card-footer">
              <span class="card-meta">{p.meta}</span>
              {p.url ? (
                <span class="card-launch btn-terminal" aria-hidden="true">{p.button.label}</span>
              ) : (
                <button
                  class="card-launch btn-terminal"
                  disabled={p.button.disabled}
                  aria-label={p.button.ariaLabel}
                >{p.button.label}</button>
              )}
            </div>
          </CardTag>
        );
      })}
    </div>
  </main>

  <DocsModal id="shortcuts-modal" title="HUB :: KEYBOARD SHORTCUTS" sections={['overview']}>
    <div slot="overview" class="shortcuts-list">
      <div class="shortcut-row"><span class="shortcut-key">[ 1 ] [ 2 ] [ 3 ] [ 4 ]</span><span class="shortcut-desc">select project by number</span></div>
      <div class="shortcut-row"><span class="shortcut-key">[ &lt;- ] [ -&gt; ] [ UP ] [ DN ]</span><span class="shortcut-desc">cycle selection</span></div>
      <div class="shortcut-row"><span class="shortcut-key">[ Enter ]</span><span class="shortcut-desc">launch selected project</span></div>
      <div class="shortcut-row"><span class="shortcut-key">[ Esc ]</span><span class="shortcut-desc">deselect</span></div>
    </div>
  </DocsModal>

  <script is:inline define:vars={{ live, total, buildDate }}>
    /* --- Boot sequence --- */
    const bootScreen = document.getElementById('boot-screen');
    const bootLinesEl = document.getElementById('boot-lines');
    const grid = document.querySelector('.project-grid');

    const bootVariants = [
      'MEM :: 512B HEAP ALLOC',
      'MEM :: 1024B HEAP ALLOC',
      'MEM :: 2048B HEAP ALLOC',
      'MEM :: 4096B HEAP ALLOC',
      'RNG :: SEED 0xA4D3F9B1',
      'RNG :: SEED 0x7FFE4B2A',
      'CACHE :: WARMED',
      'THREADS :: 4/8 ACTIVE',
      'TICK :: 24HZ LOCKED',
    ];
    const variantLine = bootVariants[Math.floor(Math.random() * bootVariants.length)];

    const bootSequence = [
      { text: `PROC SCAN :: ${live}/${total} PROJECTS LIVE`,         bright: false },
      { text: `BUILD :: ${buildDate}`,                               bright: false },
      { text: variantLine,                                           bright: false },
      { text: 'GLOW :: ON  |  SCANLINES :: ON  |  MATRIX :: STABLE', bright: false },
      { text: '> BOOT COMPLETE',                                     bright: true  },
    ];

    let bootDone = false;

    function endBoot() {
      if (bootDone) return;
      bootDone = true;
      bootScreen.classList.add('done');
      window._runCascade?.();
    }

    function runBoot() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        bootSequence.forEach(line => {
          const el = document.createElement('div');
          el.className = 'boot-line' + (line.bright ? ' bright' : '');
          el.textContent = line.text;
          bootLinesEl.appendChild(el);
        });
        endBoot();
        return;
      }
      let i = 0;
      function addLine() {
        if (bootDone) return;
        if (i >= bootSequence.length) { setTimeout(endBoot, 1500); return; }
        const el = document.createElement('div');
        el.className = 'boot-line' + (bootSequence[i].bright ? ' bright' : '');
        bootLinesEl.appendChild(el);
        const text = bootSequence[i].text;
        i++;
        const textNode = document.createTextNode('');
        const cursorSpan = document.createElement('span');
        cursorSpan.className = 'boot-cursor';
        cursorSpan.textContent = '|';
        el.appendChild(textNode);
        el.appendChild(cursorSpan);
        let c = 0;
        const type = setInterval(() => {
          if (bootDone) { clearInterval(type); cursorSpan.remove(); return; }
          textNode.textContent = text.slice(0, ++c);
          if (c >= text.length) {
            clearInterval(type);
            if (i >= bootSequence.length) {
              cursorSpan.classList.add('blinking');
              setTimeout(addLine, 200);
            } else {
              cursorSpan.remove();
              setTimeout(addLine, 200);
            }
          }
        }, 25);
      }
      addLine();
    }

    runBoot();
    bootScreen.addEventListener('click', endBoot);
    document.addEventListener('keydown', endBoot, { once: true });

    /* Shortcuts modal */
    document.getElementById('shortcuts-trigger')?.addEventListener('click', (e) => {
      const modal = document.getElementById('shortcuts-modal');
      if (!modal) return;
      modal.showModal();
      document.body.classList.add('modal-open');
      (e.currentTarget).setAttribute('aria-expanded', 'true');
    });

    /* --- Card selection & keyboard navigation --- */
    const cards = document.querySelectorAll('.project-card');
    let selectedCard = null;

    function selectCard(card) {
      if (selectedCard) {
        selectedCard.classList.remove('selected');
        selectedCard.classList.remove('kb-pulse');
      }
      selectedCard = card || null;
      if (selectedCard) selectedCard.classList.add('selected');
      /* Drop stale Tab focus on any other card so its :focus-visible highlight clears */
      cards.forEach(c => { if (c !== selectedCard && c === document.activeElement) c.blur(); });
    }

    function isNavigable(card) {
      const url = card?.dataset.url;
      return !!url && url !== '#';
    }

    function launchSelected() {
      if (!selectedCard) return;
      const btn = selectedCard.querySelector('.card-launch');
      if (btn && btn.disabled) return;
      if (isNavigable(selectedCard)) window.location.href = selectedCard.dataset.url;
    }

    cards.forEach(card => {
      card.addEventListener('click', () => {
        selectCard(card);
        /* Skip pulse on navigating click — anchor navigation itself is the feedback.
           For non-navigable cards (private/wip), pulse is the only response. */
        if (!isNavigable(card)) kbPulse(card);
      });
      /* Tab focus only — highlight via :focus-visible CSS, no .selected state.
         But clear any prior .selected so two cards aren't highlighted at once. */
      card.addEventListener('focus', () => {
        if (!card.matches(':focus-visible')) return;
        if (selectedCard && selectedCard !== card) {
          selectedCard.classList.remove('selected', 'kb-pulse');
          selectedCard = null;
        }
        kbPulse(card);
      });
    });

    document.addEventListener('click', e => {
      if (!e.target.closest('.project-card')) selectCard(null);
    });

    function kbPulse(card) {
      if (!card) return;
      card.classList.remove('kb-pulse');
      void card.offsetWidth;
      card.classList.add('kb-pulse');
    }

    document.addEventListener('keydown', e => {
      if (!bootDone) return;
      /* Suppress hub shortcuts while a modal is open — Esc/Enter/digits belong to the dialog */
      if (document.body.classList.contains('modal-open')) return;
      /* For arrow nav, use Tab-focused card as starting point if nothing is selected */
      const focusedCard = document.activeElement?.closest?.('.project-card');
      const baseIdx = selectedCard
        ? Array.from(cards).indexOf(selectedCard)
        : focusedCard ? Array.from(cards).indexOf(focusedCard) : -1;
      if (/^[1-9]$/.test(e.key)) {
        const idx = parseInt(e.key) - 1;
        if (cards[idx]) { selectCard(cards[idx]); kbPulse(cards[idx]); }
      } else if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault();
        const nextIdx = (baseIdx + 1) % cards.length;
        selectCard(cards[nextIdx]); kbPulse(cards[nextIdx]);
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault();
        const prevIdx = (baseIdx - 1 + cards.length) % cards.length;
        selectCard(cards[prevIdx]); kbPulse(cards[prevIdx]);
      } else if (e.key === 'Enter') {
        launchSelected();
      } else if (e.key === 'Escape') {
        selectCard(null);
      }
    });
  </script>
</BaseLayout>