---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 // NOT FOUND" logoText="VBSOLXTE_VXTOMVTIONS" subtitle="// Segmentation fault :: this page does not exist" hideSocial={true} errorMode={true} brokenTyping={true} noindex={true}>
  <main class="error-hub">
    <div class="glitch-text" data-text="[ 404 ]">[ 404 ]</div>
    <p class="error-caption"><span id="page-scramble">// PAGE NOT FOUND</span></p>
    <a href="/" class="btn-terminal btn-back">BACK TO HUB</a>
  </main>
</BaseLayout>

<style>
  .error-hub {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    flex-direction: column;
    gap: 24px;
    text-align: center;
  }

  .error-caption {
    color: var(--green-dim);
    font-size: 12px;
  }

  .btn-back {
    padding: 10px 24px;
    text-decoration: none;
    letter-spacing: 0.08em;
  }

  .glitch-text {
    font-size: 36px;
    letter-spacing: 0.10em;
    color: var(--green);
    position: relative;
    white-space: nowrap;
  }

  .glitch-text.is-glitching {
    animation: rgbSplit 210ms steps(1) forwards;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    color: var(--green);
    opacity: 0;
  }

  .glitch-text::before { clip-path: inset(0 0 50% 0); }
  .glitch-text::after  { clip-path: inset(50% 0 0 0); }

  .glitch-text.is-glitching::before {
    animation: glitchTop 210ms steps(1) forwards;
  }

  .glitch-text.is-glitching::after {
    animation: glitchBottom 210ms steps(1) forwards;
  }


</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const el = document.querySelector('.glitch-text');
    const scrambleEl = document.getElementById('page-scramble');
    const scrambleOriginal = scrambleEl ? scrambleEl.textContent : '';
    const glyphSet = '#@!?/\\[]<>~|=%+^&*$0123456789';
    const subtitleEl = document.querySelector('.header-left p');
    const subtitleGlyphs = '#@!?/\\[]<>~|=%+^&*$0123456789:;.,_-';
    let scrambleRunning = false;
    let subtitleRunning = false;

    function makeRandomSubtitle() {
      const len = 44;
      let s = '// ';
      for (let i = 0; i < len; i++) s += subtitleGlyphs[Math.floor(Math.random() * subtitleGlyphs.length)];
      return s;
    }

    function scrambleSubtitle() {
      if (!subtitleEl || subtitleRunning) return;
      subtitleRunning = true;
      const target = makeRandomSubtitle();
      const totalFrames = 10;
      let frame = 0;
      const iv = setInterval(() => {
        frame++;
        const resolved = Math.floor((frame / totalFrames) * target.length);
        let out = '';
        for (let i = 0; i < target.length; i++) {
          if (i < resolved || target[i] === ' ') out += target[i];
          else out += subtitleGlyphs[Math.floor(Math.random() * subtitleGlyphs.length)];
        }
        subtitleEl.textContent = out;
        if (frame >= totalFrames) {
          clearInterval(iv);
          subtitleEl.textContent = target;
          subtitleRunning = false;
        }
      }, 50);
    }

    if (subtitleEl) subtitleEl.textContent = makeRandomSubtitle();

    function triggerGlitch() {
      if (!el) return;
      el.classList.remove('is-glitching');
      void el.offsetWidth;
      el.classList.add('is-glitching');
      setTimeout(() => el.classList.remove('is-glitching'), 230);
    }

    function runScramble() {
      if (!scrambleEl || scrambleRunning) return;
      scrambleRunning = true;
      const totalFrames = 10;
      let frame = 0;
      const iv = setInterval(() => {
        frame++;
        const resolved = Math.floor((frame / totalFrames) * scrambleOriginal.length);
        let out = '';
        for (let i = 0; i < scrambleOriginal.length; i++) {
          if (i < resolved || scrambleOriginal[i] === ' ') out += scrambleOriginal[i];
          else out += glyphSet[Math.floor(Math.random() * glyphSet.length)];
        }
        scrambleEl.textContent = out;
        if (frame >= totalFrames) {
          clearInterval(iv);
          scrambleEl.textContent = scrambleOriginal;
          scrambleRunning = false;
        }
      }, 50);
    }

    // First glitch after 7s, then every 7s. typeLogo on every 2nd glitch.
    setTimeout(() => {
      let tick = 0;
      triggerGlitch();
      runScramble();
      setInterval(() => {
        tick++;
        triggerGlitch();
        runScramble();
        scrambleSubtitle();
        if (tick % 2 === 1) typeLogo();
      }, 7000);
    }, 7000);
  });
</script>
