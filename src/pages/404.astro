---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 // NOT FOUND" logoText="VBSOLXTE_VXTOMVTIONS" subtitle="ERR!: Segmentation fault :: this page does not exist" hideSocial={true} errorMode={true} brokenTyping={true} noindex={true}>
  <main class="error-hub">
    <div class="error-main" data-cascade-item>
      <div class="glitch-text" data-text="[ 404 ]">[ 404 ]</div>
      <p class="error-caption"><span id="page-scramble">PAGE NOT FOUND</span></p>
    </div>
    <a href="/" class="btn-terminal btn-back" data-cascade-item>REBOOT SYSTEM</a>
  </main>
</BaseLayout>

<style>
  .error-hub {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    flex-direction: column;
    gap: 24px;
    text-align: center;
  }

  .error-main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .error-caption {
    color: var(--green-dim);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
  }

  .btn-back {
    padding: 12px 32px;
    font-size: 16px;
    text-decoration: none;
  }

  .glitch-text {
    font-size: 36px;
    letter-spacing: 0.10em;
    color: var(--green);
    position: relative;
    white-space: nowrap;
  }

  .glitch-text.is-glitching {
    animation: rgbSplit 210ms steps(1) forwards;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    color: var(--green);
    opacity: 0;
  }

  .glitch-text::before { clip-path: inset(0 0 50% 0); }
  .glitch-text::after  { clip-path: inset(50% 0 0 0); }

  .glitch-text.is-glitching::before {
    animation: glitchTop 210ms steps(1) forwards;
  }

  .glitch-text.is-glitching::after {
    animation: glitchBottom 210ms steps(1) forwards;
  }


</style>

<script>
  import '../scripts/error-glitch';
</script>
