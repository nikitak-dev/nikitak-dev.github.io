---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 // NOT FOUND" hideSocial={true} errorMode={true}>
  <main id="hub" style="display:flex;align-items:center;justify-content:center;min-height:60vh;flex-direction:column;gap:24px;text-align:center;">
    <div class="glitch-text" data-text="[ 404 ]">[ 404 ]</div>
    <p style="color:var(--green-dim);font-size:1rem;">// PAGE NOT FOUND</p>
    <a href="/" class="card-launch btn-back">&lt;&lt; BACK TO HUB</a>
  </main>
</BaseLayout>

<style>
  .btn-back {
    padding: 10px 24px;
    text-decoration: none;
    background: var(--bg-elevated);
  }
  .btn-back:hover {
    background: rgba(0, 255, 65, 0.15);
  }

  .glitch-text {
    font-size: 3rem;
    letter-spacing: 0.1em;
    color: var(--green);
    position: relative;
    white-space: nowrap;
  }

  .glitch-text.is-glitching {
    animation: g404-rgb 210ms steps(1) forwards;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    color: var(--green);
    opacity: 0;
  }

  .glitch-text::before { clip-path: inset(0 0 50% 0); }
  .glitch-text::after  { clip-path: inset(50% 0 0 0); }

  .glitch-text.is-glitching::before {
    animation: g404-top 210ms steps(1) forwards;
  }

  .glitch-text.is-glitching::after {
    animation: g404-bottom 210ms steps(1) forwards;
  }

  @keyframes g404-rgb {
    0%   { filter: drop-shadow(-6px 0 rgba(255,0,64,0.9))  drop-shadow(6px 0 rgba(0,255,255,0.9)); }
    17%  { filter: drop-shadow(-10px 0 rgba(255,0,64,0.8)) drop-shadow(4px 0 rgba(0,255,255,0.8)); }
    33%  { filter: drop-shadow(-4px 0 rgba(255,0,64,0.95)) drop-shadow(10px 0 rgba(0,255,255,0.95)); }
    50%  { filter: drop-shadow(-8px 0 rgba(255,0,64,0.7))  drop-shadow(7px 0 rgba(0,255,255,0.7)); }
    67%  { filter: drop-shadow(-12px 0 rgba(255,0,64,0.9)) drop-shadow(3px 0 rgba(0,255,255,0.9)); }
    83%  { filter: drop-shadow(-3px 0 rgba(255,0,64,0.4))  drop-shadow(8px 0 rgba(0,255,255,0.4)); }
    100% { filter: none; }
  }

  @keyframes g404-top {
    0%   { transform: translateX(-8px); opacity: 1; }
    17%  { transform: translateX(6px); opacity: 1; }
    33%  { transform: translateX(-3px); opacity: 1; }
    50%  { transform: translateX(10px); opacity: 1; }
    67%  { transform: translateX(-5px); opacity: 1; }
    83%  { transform: translateX(2px); opacity: 1; }
    100% { transform: none; opacity: 0; }
  }

  @keyframes g404-bottom {
    0%   { transform: translateX(7px); opacity: 1; }
    17%  { transform: translateX(-10px); opacity: 1; }
    33%  { transform: translateX(4px); opacity: 1; }
    50%  { transform: translateX(-6px); opacity: 1; }
    67%  { transform: translateX(8px); opacity: 1; }
    83%  { transform: translateX(-3px); opacity: 1; }
    100% { transform: none; opacity: 0; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof logoLoopInterval !== 'undefined') clearInterval(logoLoopInterval);

    const el = document.querySelector('.glitch-text');

    function triggerGlitch() {
      if (!el) return;
      el.classList.remove('is-glitching');
      void el.offsetWidth;
      el.classList.add('is-glitching');
      setTimeout(() => el.classList.remove('is-glitching'), 230);
    }

    // First glitch after 6s, then every 6s. typeLogo on every 2nd glitch.
    setTimeout(() => {
      let tick = 0;
      triggerGlitch();
      setInterval(() => {
        tick++;
        triggerGlitch();
        if (tick % 2 === 1) typeLogo();
      }, 6000);
    }, 6000);
  });
</script>
