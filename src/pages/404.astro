---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 // NOT FOUND" hideSocial={true} errorMode={true}>
  <main id="hub" style="display:flex;align-items:center;justify-content:center;min-height:60vh;flex-direction:column;gap:24px;text-align:center;">
    <div class="glitch-text" data-text="[ 404 ]">[ 404 ]</div>
    <p style="color:var(--green-dim);font-size:12px;">// PAGE NOT FOUND</p>
    <a href="/" class="card-launch btn-back">&lt;&lt; BACK TO HUB</a>
  </main>
</BaseLayout>

<style>
  .btn-back {
    padding: 10px 24px;
    text-decoration: none;
    background: var(--bg-elevated);
  }
  .btn-back:hover {
    background: rgba(0, 255, 65, 0.15);
  }

  .glitch-text {
    font-size: 36px;
    letter-spacing: 0.1em;
    color: var(--green);
    position: relative;
    white-space: nowrap;
  }

  .glitch-text.is-glitching {
    animation: rgbSplit 210ms steps(1) forwards;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    color: var(--green);
    opacity: 0;
  }

  .glitch-text::before { clip-path: inset(0 0 50% 0); }
  .glitch-text::after  { clip-path: inset(50% 0 0 0); }

  .glitch-text.is-glitching::before {
    animation: glitchTop 210ms steps(1) forwards;
  }

  .glitch-text.is-glitching::after {
    animation: glitchBottom 210ms steps(1) forwards;
  }


</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof logoLoopInterval !== 'undefined') clearInterval(logoLoopInterval);

    const el = document.querySelector('.glitch-text');

    function triggerGlitch() {
      if (!el) return;
      el.classList.remove('is-glitching');
      void el.offsetWidth;
      el.classList.add('is-glitching');
      setTimeout(() => el.classList.remove('is-glitching'), 230);
    }

    // First glitch after 6s, then every 6s. typeLogo on every 2nd glitch.
    setTimeout(() => {
      let tick = 0;
      triggerGlitch();
      setInterval(() => {
        tick++;
        triggerGlitch();
        if (tick % 2 === 1) typeLogo();
      }, 7000);
    }, 7000);
  });
</script>
