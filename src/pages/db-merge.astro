---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocsModal from '../components/DocsModal.astro';
import DocsTrigger from '../components/DocsTrigger.astro';
---
<BaseLayout
  title="DB_MERGE // Database Reconciliation"
  logoText="DB_MERGE"
  subtitle="// merge and normalize records across several databases"
  theme="amber"
  hideSocial={true}
  emptyFooter={true}
  backHref="/"
  scanlineMode="global"
  description="DB_MERGE — automation for merging and normalizing records across multiple databases."
  ogTitle="DB_MERGE // Database Reconciliation"
  ogDescription="Automation that merges and normalizes records across multiple databases."
>
  <DocsTrigger slot="header-action" />
  <main id="db-merge-page"></main>
  <DocsModal id="docs-modal" title="PROJECT :: DB_MERGE" />
</BaseLayout>

<style>
  #db-merge-page { flex: 1; }
</style>
