---
import '../styles/global.css';
import MatrixRain from '../components/MatrixRain.astro';
import TypeLogo from '../components/TypeLogo.astro';
const {
  title = 'ABSOLUTE // Automations Portfolio',
  logoText = 'ABSOLUTE_AUTOMATIONS',
  subtitle = '// Every repetitive task is a bug I can fix',
  hideSocial = false,
  hideFooter = false,
  errorMode = false,
  brokenTyping = false,
  backHref = null,
  backHoverText = 'ABSOLUTE_AUTOMATIONS',
  procLive = 2,
  procTotal = 4,
  scanlineMode = 'global',
  description = 'AI automation portfolio: n8n, Claude, Supabase, VAPI. Multimodal RAG, Voice AI agents, and more. Available for remote freelance.',
  ogTitle = title,
  ogDescription = description,
  noindex = false,
  preconnectWebhook = false,
} = Astro.props;

// Derive webhook origin for CSP connect-src. Falls back to empty when env
// is missing so the header stays valid (fetch just fails on 'self' only).
const webhookUrl = import.meta.env.PUBLIC_RAG_WEBHOOK;
const webhookOrigin = webhookUrl ? new URL(webhookUrl).origin : '';
const csp = [
  "default-src 'self'",
  `connect-src 'self'${webhookOrigin ? ' ' + webhookOrigin : ''}`,
  "img-src 'self' data: https://drive.google.com",
  "frame-src https://drive.google.com",
  "font-src https://fonts.gstatic.com",
  "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
  "script-src 'self' 'unsafe-inline'",
  "base-uri 'none'",
  "form-action 'self'",
  "object-src 'none'",
].join('; ');

const buildTime = new Date().toISOString();
const siteUrl = 'https://nikitak-dev.github.io/';
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': siteUrl + '#person',
      name: 'Nikita Kurdybailo',
      url: siteUrl,
      jobTitle: 'AI Automation & Integration Specialist',
      sameAs: [
        'https://github.com/nikitak-dev',
        'https://www.linkedin.com/in/nikita-kurdybailo-b0438a333',
        'https://t.me/nikitadev001',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': siteUrl + '#website',
      url: siteUrl,
      name: 'ABSOLUTE // Automations Portfolio',
      description: 'AI automation portfolio: n8n, Claude, Supabase, VAPI. Multimodal RAG, Voice AI agents, and more. Available for remote freelance.',
      author: { '@id': siteUrl + '#person' },
    },
  ],
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Security-Policy" content={csp}>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" type="image/png" sizes="32x32" href="data:image/png;base64,">
  <meta name="description" content={description}>
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url} />
  <meta property="og:image" content="https://nikitak-dev.github.io/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="theme-color" content="#000000">
  <meta name="color-scheme" content="dark">
  <style>html{background:#000}body{color:#00ff41}</style>
  <link rel="canonical" href={Astro.url} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {preconnectWebhook && webhookOrigin && <link rel="preconnect" href={webhookOrigin} crossorigin />}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
</head>
<body data-error={errorMode ? 'true' : 'false'} class={scanlineMode !== 'global' ? 'no-global-scanlines' : ''}>
  <MatrixRain />
  <div class="overlay-vignette"></div>

  <header class={scanlineMode === 'per-section' ? 'scanlines-section' : ''}>
    <div class="header-left">
      <h1>
        {backHref ? (
          <a
            href={backHref}
            class="logo-back"
            style={`min-width: ${Math.max(logoText.length, backHoverText.length)}ch`}
            aria-label={`Back (${backHoverText})`}
          ><span id="logo-text"></span><span class="cursor" aria-hidden="true"></span></a>
        ) : (
          <><span id="logo-text"></span><span class="cursor" aria-hidden="true"></span></>
        )}
      </h1>
      <p>{subtitle}</p>
      <TypeLogo text={logoText} speed={70} broken={brokenTyping} />
    </div>
    {Astro.slots.has('header-action') ? (
      <div class="header-action"><slot name="header-action" /></div>
    ) : !hideSocial ? (
      <nav class="social-links" role="navigation" aria-label="Social links">
        <a href="https://github.com/nikitak-dev" target="_blank" rel="noopener noreferrer" class="btn-terminal">GitHub</a>
        <a href="https://www.linkedin.com/in/nikita-kurdybailo-b0438a333" target="_blank" rel="noopener noreferrer" class="btn-terminal">LinkedIn</a>
        <a href="https://t.me/nikitadev001" target="_blank" rel="noopener noreferrer" class="btn-terminal">Telegram</a>
      </nav>
    ) : null}
  </header>

  <slot />

  {!hideFooter && (
  <footer class="hub-footer">
    {!errorMode && <span>© 2026 ABSOLUTE</span>}
    <div class:list={['sys-status', errorMode && 'sys-status--end']}>
      <span>{errorMode ? '[ SYS: ERROR ]' : '[ SYS: NOMINAL ]'}</span>
      <span>[ UPTIME: <span id="uptime-val">{errorMode ? '--' : '0d 0h'}</span> ]</span>
      <span>{errorMode ? `[ PROC: 0/${procTotal} LIVE ]` : `[ PROC: ${procLive}/${procTotal} LIVE ]`}</span>
      {errorMode
        ? <span class="status-block-dead">[ CONN: LOST ]</span>
        : <span class="status-block-live">[ CONN: ESTABLISHED ]</span>
      }
    </div>
  </footer>
  )}

  <script is:inline define:vars={{ buildTime }}>
    /* --- Logo loop --- */
    var logoLoopTimer = null;
    function scheduleLogoLoop() {
      if (logoLoopTimer) clearTimeout(logoLoopTimer);
      logoLoopTimer = setTimeout(() => {
        logoLoopTimer = null;
        typeLogo();
        scheduleLogoLoop();
      }, 14000);
    }
    window._logoTimerStop = () => {
      if (logoLoopTimer) clearTimeout(logoLoopTimer);
      logoLoopTimer = null;
    };
    window._logoTimerReset = scheduleLogoLoop;
    scheduleLogoLoop();

    /* --- Footer uptime counter --- */
    const BOOT_DATE = new Date(buildTime);
    const uptimeEl = document.getElementById('uptime-val');

    function updateUptime() {
      const diff = Math.max(0, Date.now() - BOOT_DATE.getTime());
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);
      uptimeEl.textContent = `${days}d ${hours}h ${mins}m`;
    }

    if (uptimeEl && document.body.dataset.error !== 'true') {
      updateUptime();
      var uptimeInterval = setInterval(updateUptime, 60000);
    }

    window.addEventListener('beforeunload', () => {
      if (logoLoopTimer) clearTimeout(logoLoopTimer);
      if (typeof uptimeInterval !== 'undefined') clearInterval(uptimeInterval);
    });
  </script>

  {backHref && (
    <script is:inline define:vars={{ backHoverText, originalLogoText: logoText, speed: 70 }}>
      (function () {
        const anchor = document.querySelector('h1 a.logo-back');
        const logoEl = document.getElementById('logo-text');
        if (!anchor || !logoEl) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        let animIv = null;
        let currentTarget = null;

        function animateTo(target) {
          if (animIv) { clearInterval(animIv); animIv = null; }
          if (currentTarget === target) return;
          currentTarget = target;
          window._logoHoverActive = true;
          if (target !== originalLogoText) window._logoTimerStop && window._logoTimerStop();
          // phase 1: erase
          animIv = setInterval(() => {
            const cur = logoEl.textContent;
            if (cur.length > 0) {
              logoEl.textContent = cur.slice(0, -1);
              return;
            }
            clearInterval(animIv);
            // phase 2: type target
            let i = 0;
            animIv = setInterval(() => {
              logoEl.textContent += target[i];
              i++;
              if (i >= target.length) {
                clearInterval(animIv);
                animIv = null;
                if (target === originalLogoText) {
                  window._logoHoverActive = false;
                  window._logoTimerReset && window._logoTimerReset();
                }
              }
            }, speed);
          }, speed);
        }

        anchor.addEventListener('mouseenter', () => animateTo(backHoverText));
        anchor.addEventListener('mouseleave', () => animateTo(originalLogoText));
        anchor.addEventListener('focus', () => animateTo(backHoverText));
        anchor.addEventListener('blur', () => animateTo(originalLogoText));

        window.addEventListener('beforeunload', () => {
          if (animIv) clearInterval(animIv);
        });
      })();
    </script>
  )}
</body>
</html>
