---
import '../styles/global.css';
import MatrixRain from '../components/MatrixRain.astro';
import TypeLogo from '../components/TypeLogo.astro';
const {
  title = 'ABSOLUTE // Automations Portfolio',
  logoText = 'ABSOLUTE_AUTOMATIONS',
  subtitle = '// Every repetitive task is a bug I can fix',
  hideSocial = false,
  hideFooter = false,
  errorMode = false,
  breadcrumb = null,
  procLive = 2,
  procTotal = 4,
  scanlineMode = 'global',
  description = 'AI automation portfolio: n8n, Claude, Supabase, VAPI. Multimodal RAG, Voice AI agents, and more. Available for remote freelance.',
  ogTitle = title,
  ogDescription = description,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" type="image/png" sizes="32x32" href="data:image/png;base64,">
  <meta name="description" content={description}>
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url} />
  <meta property="og:image" content="https://nikitak-dev.github.io/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="theme-color" content="#000000">
  <link rel="canonical" href={Astro.url} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=block" rel="stylesheet">
</head>
<body data-error={errorMode ? 'true' : 'false'} class={scanlineMode !== 'global' ? 'no-global-scanlines' : ''}>
  <MatrixRain />
  <div class="overlay-vignette"></div>

  <header class={scanlineMode === 'per-section' ? 'scanlines-section' : ''}>
    <div class="header-left">
      {breadcrumb && (
        <div class="nav-breadcrumb">
          <a href={breadcrumb.href}>&lt;&lt; {breadcrumb.label}</a>
        </div>
      )}
      <h1><span id="logo-text"></span><span class="cursor" aria-hidden="true"></span></h1>
      <p>{subtitle}</p>
      <TypeLogo text={logoText} speed={70} />
    </div>
    {Astro.slots.has('header-action') ? (
      <div class="header-action"><slot name="header-action" /></div>
    ) : !hideSocial ? (
      <nav class="social-links" role="navigation" aria-label="Social links">
        <a href="https://github.com/nikitak-dev" target="_blank" rel="noopener" class="btn-terminal">GitHub</a>
        <a href="https://www.linkedin.com/in/nikita-kurdybailo-b0438a333" target="_blank" rel="noopener" class="btn-terminal">LinkedIn</a>
        <a href="https://t.me/nikitadev001" target="_blank" rel="noopener" class="btn-terminal">Telegram</a>
      </nav>
    ) : null}
  </header>

  <slot />

  {!hideFooter && (
  <footer class="hub-footer">
    {!errorMode && <span>© 2026 ABSOLUTE</span>}
    <div class="sys-status" style={errorMode ? 'margin-left:auto' : ''}>
      <span>{errorMode ? '[ SYS: ERROR ]' : '[ SYS: NOMINAL ]'}</span>
      <span>[ UPTIME: <span id="uptime-val">{errorMode ? '--' : '0d 0h'}</span> ]</span>
      <span>{errorMode ? `[ PROC: 0/${procTotal} LIVE ]` : `[ PROC: ${procLive}/${procTotal} LIVE ]`}</span>
      {errorMode
        ? <span class="status-block-dead">[ CONN: LOST ]</span>
        : <span class="status-block-live">[ CONN: ESTABLISHED ]</span>
      }
    </div>
  </footer>
  )}

  <script is:inline>
    /* --- Logo loop --- */
    var logoLoopInterval = setInterval(typeLogo, 14000);

    /* --- Footer uptime counter --- */
    const BOOT_DATE = new Date('2026-04-12T14:00:00+02:00');
    const uptimeEl = document.getElementById('uptime-val');

    function updateUptime() {
      const diff = Math.max(0, Date.now() - BOOT_DATE.getTime());
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);
      uptimeEl.textContent = `${days}d ${hours}h ${mins}m`;
    }

    if (uptimeEl && document.body.dataset.error !== 'true') {
      updateUptime();
      var uptimeInterval = setInterval(updateUptime, 60000);
    }

    window.addEventListener('beforeunload', () => {
      clearInterval(logoLoopInterval);
      if (typeof uptimeInterval !== 'undefined') clearInterval(uptimeInterval);
    });
  </script>
</body>
</html>
