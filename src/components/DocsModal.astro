---
interface Props {
  id: string;
  title?: string;
  sections?: Array<'overview' | 'demo'>;
}
const { id, title = 'PROJECT :: DOCUMENTATION', sections = ['overview', 'demo'] } = Astro.props;
const titleId = `${id}-title`;
---
<dialog id={id} class="docs-modal" aria-labelledby={titleId} closedby="any">
  <div class="modal-frame scanlines-section">
    <header class="modal-header">
      <h2 id={titleId} class="modal-title">// {title}</h2>
      <button type="button" class="modal-close btn-terminal" aria-label="Close dialog">[ CLOSE ]</button>
    </header>
    {sections.includes('overview') && (
      <section class="modal-section">
        <div class="section-label">// OVERVIEW</div>
        <slot name="overview">
          <div class="slot-empty">[ DOCS :: COMING SOON ]</div>
        </slot>
      </section>
    )}
    {sections.includes('demo') && (
      <section class="modal-section">
        <div class="section-label">// DEMO</div>
        <slot name="demo">
          <div class="video-slot">[ VIDEO :: COMING SOON ]</div>
        </slot>
      </section>
    )}
  </div>
</dialog>

<script is:inline define:vars={{ id }}>
  (function () {
    const modal = document.getElementById(id);
    if (!modal) return;

    const closeBtn = modal.querySelector('.modal-close');
    closeBtn && closeBtn.addEventListener('click', () => modal.close());

    /* body.modal-open cleanup on close — parent sets it on open.
       Also blur the trigger after native focus-restore: Escape-close restores focus with
       keyboard context, so :focus-visible lingers on the opener and it looks "selected". */
    modal.addEventListener('close', () => {
      document.body.classList.remove('modal-open');
      requestAnimationFrame(() => {
        const active = document.activeElement;
        if (active instanceof HTMLElement && active !== document.body) active.blur();
      });
    });

    /* Drag-close fix: only close on backdrop click if mousedown+mouseup both on dialog itself */
    let downTarget = null;
    modal.addEventListener('mousedown', e => { downTarget = e.target; });
    modal.addEventListener('mouseup', e => {
      if (e.target === modal && downTarget === modal) modal.close();
    });

    /* Fallback for closedby="any" (Chrome 134+/Safari 18+). Older browsers: bind Escape + backdrop manually.
       If native closedby works, it fires close() — our drag-fix above still guards against accidental drag-close. */
    const supportsClosedBy = 'closedBy' in modal;
    if (!supportsClosedBy) {
      modal.addEventListener('cancel', e => { /* Escape already closes via native cancel event */ });
    }
  })();
</script>

<style is:global>
  dialog.docs-modal {
    margin: auto;
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
    min-width: min(560px, calc(100vw - 32px));
    max-width: min(720px, calc(100vw - 32px));
    max-height: 80vh;
    overflow: visible;
    opacity: 0;
    transform: translateY(10px) scale(0.97);
    transition:
      opacity 320ms ease-in,
      transform 320ms ease-in,
      overlay 320ms ease-in allow-discrete,
      display 320ms ease-in allow-discrete;
  }
  dialog.docs-modal[open] {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition:
      opacity 320ms ease-out,
      transform 320ms ease-out,
      overlay 320ms ease-out allow-discrete,
      display 320ms ease-out allow-discrete;
  }
  @starting-style {
    dialog.docs-modal[open] {
      opacity: 0;
      transform: translateY(10px) scale(0.97);
    }
  }

  dialog.docs-modal::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition:
      opacity 320ms ease-in,
      overlay 320ms ease-in allow-discrete,
      display 320ms ease-in allow-discrete;
  }
  dialog.docs-modal[open]::backdrop {
    opacity: 1;
    transition:
      opacity 320ms ease-out,
      overlay 320ms ease-out allow-discrete,
      display 320ms ease-out allow-discrete;
  }
  @starting-style {
    dialog.docs-modal[open]::backdrop { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    dialog.docs-modal,
    dialog.docs-modal::backdrop { transition: none; }
  }

  body.modal-open::after { display: none; }

  .docs-modal .modal-frame {
    position: relative;
    border: 1px solid var(--border-hover);
    background: var(--bg-elevated);
    padding: 24px 28px;
    max-height: 80vh;
    overflow-y: auto;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
    scrollbar-color: var(--green-muted) transparent;
    animation: docs-modal-breathe 3s linear infinite;
  }
  @keyframes docs-modal-breathe {
    0%, 100% {
      border-color: var(--green-muted);
      box-shadow: 0 0 8px var(--green-glow), inset 0 0 4px var(--green-glow);
    }
    50% {
      border-color: var(--green);
      box-shadow: 0 0 24px var(--green-glow-strong), inset 0 0 14px var(--green-glow-strong);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .docs-modal .modal-frame { animation: none; }
  }
  .docs-modal .modal-frame::-webkit-scrollbar { width: 4px; }
  .docs-modal .modal-frame::-webkit-scrollbar-track { background: transparent; }
  .docs-modal .modal-frame::-webkit-scrollbar-thumb { background: var(--green-muted); border-radius: 2px; }

  .docs-modal .modal-header {
    position: relative;
    container-type: inline-size;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 16px;
  }
  .docs-modal .modal-header::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 1px;
    background-color: var(--border);
    background-image: linear-gradient(90deg,
      transparent 17.5%,
      var(--green) 25%,
      transparent 32.5%,
      transparent 67.5%,
      var(--green) 75%,
      transparent 82.5%);
    background-size: 200% 100%;
    background-repeat: repeat-x;
    animation: docs-modal-beam 3s linear infinite;
    pointer-events: none;
    filter: drop-shadow(0 0 3px var(--green-dim));
  }
  @keyframes docs-modal-beam {
    from { background-position-x: 0%; }
    to   { background-position-x: -100%; }
  }
  .docs-modal .modal-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.10em;
    color: var(--green);
    text-transform: uppercase;
    text-shadow: 0 0 8px var(--green-glow-strong);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .docs-modal .modal-close {
    padding: 6px 14px;
    font-size: 11px;
    flex-shrink: 0;
  }

  .docs-modal .modal-section { margin-bottom: 24px; }
  .docs-modal .modal-section:last-child { margin-bottom: 0; }

  .docs-modal .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    color: var(--green-mid);
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .docs-modal .slot-empty {
    padding: 32px 16px;
    text-align: center;
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 0.06em;
    border: 1px dashed var(--border-hover);
    background: var(--bg-input);
  }

  .docs-modal .video-slot {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--border-hover);
    background: var(--bg-input);
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 0.06em;
  }
</style>
