---
interface Props {
  id: string;
  title?: string;
  sections?: Array<'overview' | 'demo'>;
  /** `amber` remaps the dialog's green-* tokens to amber-* via `.theme-amber` (automation projects). */
  theme?: 'green' | 'amber';
}
const { id, title = 'PROJECT :: DOCUMENTATION', sections = ['overview', 'demo'], theme = 'green' } = Astro.props;
const titleId = `${id}-title`;
---
<dialog id={id} class:list={['docs-modal', { 'theme-amber': theme === 'amber' }]} aria-labelledby={titleId} closedby="any">
  <div class="modal-frame">
    <div class="modal-header">
      <h2 id={titleId} class="modal-title">{title}</h2>
      <button type="button" class="modal-close btn-terminal" aria-label="Close dialog">CLOSE</button>
    </div>
    {sections.includes('overview') && (
      <section class="modal-section">
        <div class="section-label">// OVERVIEW</div>
        <slot name="overview">
          <div class="slot-empty">[ DOCS :: COMING SOON ]</div>
        </slot>
      </section>
    )}
    {sections.includes('demo') && (
      <section class="modal-section">
        <div class="section-label">// DEMO</div>
        <slot name="demo">
          <div class="video-slot">[ VIDEO :: COMING SOON ]</div>
        </slot>
      </section>
    )}
  </div>
</dialog>

<script is:inline define:vars={{ id }}>
  (function () {
    const modal = document.getElementById(id);
    if (!modal) return;

    const closeBtn = modal.querySelector('.modal-close');
    closeBtn && closeBtn.addEventListener('click', () => modal.close());

    /* The trigger that opened the modal, so focus can be returned to it on close.
       For a hub card this is the card's ABOUT button — restoring focus there puts the
       user back on the card (re-selecting it) instead of dropping focus to <body>,
       which native <dialog> does when the modal was opened by a relayed/mouse click. */
    let opener = null;

    /* Auto-wire any element with aria-controls=<id> to open this modal, so
       page markup stays declarative — callers just add the a11y attribute. */
    document.querySelectorAll(`[aria-controls="${id}"]`).forEach(trigger => {
      trigger.addEventListener('click', () => {
        if (modal.open) return;
        opener = trigger;
        modal.showModal();
        document.body.classList.add('modal-open');
        trigger.setAttribute('aria-expanded', 'true');
        /* Land focus on CLOSE so a keyboard-opened modal can be dismissed with the
           same key. :focus-visible only flares it when the open was keyboard-driven. */
        closeBtn && closeBtn.focus();
      });
    });

    modal.addEventListener('close', () => {
      document.body.classList.remove('modal-open');
      document.querySelectorAll(`[aria-controls="${id}"]`).forEach(t => t.setAttribute('aria-expanded', 'false'));
      /* Return focus to the opening trigger (the card), not wherever native restore lands. */
      if (opener) { opener.focus({ preventScroll: true }); opener = null; }
    });

    /* Drag-close fix: only close on backdrop click if mousedown+mouseup both on dialog itself.
       Escape closes via the native <dialog> cancel event on every supported browser; closedby="any"
       (Chrome 134+/Safari 18+) also fires close() on outside-click — the drag-fix still applies. */
    let downTarget = null;
    modal.addEventListener('mousedown', e => { downTarget = e.target; });
    modal.addEventListener('mouseup', e => {
      if (e.target === modal && downTarget === modal) modal.close();
    });
  })();
</script>
