---
// Header button that opens the project DocsModal. Placed into BaseLayout's
// header-action slot at the call site: <DocsTrigger slot="header-action" />.
// Pairs with <DocsModal id="docs-modal" /> via aria-controls.
---
<button
  type="button"
  id="docs-trigger"
  class="btn-terminal"
  aria-haspopup="dialog"
  aria-controls="docs-modal"
  aria-expanded="false"
>ABOUT</button>
