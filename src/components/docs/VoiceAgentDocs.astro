  /* Smooth-scroll for in-document references inside the voice-agent docs modal.
     Same pattern as MultimodalRagDocs — kept duplicated rather than extracted
     because each component owns its own scoped behaviour. */
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const link = target.closest('.project-docs .docs-ref');
    if (!link) return;
    const href = link.getAttribute('href') || '';
    if (!href.startsWith('#')) return;
    const dest = document.getElementById(href.slice(1));
    if (!dest) return;
    event.preventDefault();
    dest.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
