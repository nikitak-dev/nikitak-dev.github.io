---
// MatrixRain: shared canvas animation component
// Used by BaseLayout and multimodal-rag
---
<canvas id="matrix-bg"></canvas>
<canvas id="matrix-lens" aria-hidden="true"></canvas>

<style is:global>
  #matrix-bg {
    filter: blur(3px);
  }
  #matrix-lens {
    position: fixed;
    inset: 0;
    z-index: -1;
    opacity: 0.55;
    pointer-events: none;
    mask-image: radial-gradient(circle 120px at var(--cx, -200px) var(--cy, -200px),
      #000 0%, rgba(0,0,0,0.92) 30%, rgba(0,0,0,0.6) 55%, rgba(0,0,0,0.25) 80%, transparent 100%);
    -webkit-mask-image: radial-gradient(circle 120px at var(--cx, -200px) var(--cy, -200px),
      #000 0%, rgba(0,0,0,0.92) 30%, rgba(0,0,0,0.6) 55%, rgba(0,0,0,0.25) 80%, transparent 100%);
  }
  @media (prefers-reduced-motion: reduce), (hover: none) {
    #matrix-bg { filter: none; }
    #matrix-lens { display: none; }
  }
</style>

<script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const canvas = document.getElementById('matrix-bg');
    const ctx = canvas.getContext('2d');
    const lens = document.getElementById('matrix-lens');
    const lensCtx = lens ? lens.getContext('2d') : null;
    const fontSize = 14;
    const errorMode = document.body.dataset.error === 'true';

    const chars = errorMode ? 'ERR!?@#$%^&*<>/\\~|:;' : '01';
    const mainColor  = errorMode ? '#ff3333' : '#00ff41';
    const trailColor = errorMode ? 'rgba(255, 51, 51, 0.4)' : 'rgba(0, 255, 65, 0.4)';
    const glyphCyclingRate = errorMode ? 0.05 : 0;

    let columns, drops, speedFactors, cells;

    function initMatrix() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      if (lens) { lens.width = window.innerWidth; lens.height = window.innerHeight; }
      const rows = Math.ceil(canvas.height / fontSize);
      columns = Math.floor(canvas.width / fontSize);
      drops = Array.from({ length: columns }, () => -Math.floor(Math.random() * rows));
      speedFactors = Array.from({ length: columns }, () => 0.5 + Math.random());
      cells = Array.from({ length: columns }, () => []);
      jumpsRemaining = Array.from({ length: columns }, () => errorMode ? 2 : 0);
      ghosts = [];
    }

    window.__matrixIntensify = (x, y, radius = 140, duration = 500) => {
      boosts.push({ x, y, r2: radius * radius, until: performance.now() + duration });
    };


    let lastTime = 0;
    const interval = 80; // ~12.5 fps
    let rafId = null;

    let ghosts = [];
    let jumpsRemaining;

    function drawMatrix(timestamp) {
      rafId = requestAnimationFrame(drawMatrix);
      if (timestamp - lastTime < interval) return;
      lastTime = timestamp;

      ctx.fillStyle = 'rgba(0, 0, 0, 0.06)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.font = `${fontSize}px JetBrains Mono, monospace`;

      for (let i = 0; i < drops.length; i++) {
        if (drops[i] < 0) { drops[i] += speedFactors[i]; continue; }

        const x = i * fontSize;
        const y = Math.floor(drops[i]) * fontSize;
        const char = chars[Math.floor(Math.random() * chars.length)];

        ctx.fillStyle = mainColor;
        ctx.fillText(char, x, y);
        if (y - fontSize > 0) {
          ctx.fillStyle = trailColor;
          ctx.fillText(chars[Math.floor(Math.random() * chars.length)], x, y - fontSize);
        }

        // 4.4 In-place glyph cycling (error mode only)
        if (glyphCyclingRate > 0 && cells[i].length > 0 && Math.random() < glyphCyclingRate) {
          const cell = cells[i][Math.floor(Math.random() * cells[i].length)];
          ctx.fillStyle = mainColor;
          ctx.fillText(chars[Math.floor(Math.random() * chars.length)], cell.x, cell.y);
        }

        cells[i].push({ x, y });
        if (cells[i].length > 20) cells[i].shift();

        // Error-mode: rare head-jump to another lane, leaves a trail
        if (jumpsRemaining[i] > 0 && y > 0 && y < canvas.height && Math.random() < 0.004) {
          const targetCol = Math.floor(Math.random() * columns);
          if (targetCol !== i) {
            ghosts.push({
              startX: x,
              targetX: targetCol * fontSize,
              y,
              char: chars[Math.floor(Math.random() * chars.length)],
              frame: 0,
              totalFrames: 4 + Math.floor(Math.random() * 3),
            });
            jumpsRemaining[i]--;
          }
        }

        if (y > canvas.height && Math.random() > 0.975) {
          drops[i] = -Math.floor(Math.random() * 30);
          cells[i].length = 0;
          if (errorMode) jumpsRemaining[i] = 2;
        }
        drops[i] += speedFactors[i]; // 4.2 variable speed
      }

      // Advance ghost jumps (error mode only; empty otherwise)
      if (ghosts.length > 0) {
        for (let g = ghosts.length - 1; g >= 0; g--) {
          const ghost = ghosts[g];
          const t0 = ghost.frame / ghost.totalFrames;
          ghost.frame++;
          const t1 = ghost.frame / ghost.totalFrames;
          const x0 = ghost.startX + (ghost.targetX - ghost.startX) * t0;
          const x1 = ghost.startX + (ghost.targetX - ghost.startX) * t1;
          const dx = x1 - x0;
          const stepSize = fontSize * 0.6;
          const numSteps = Math.max(1, Math.ceil(Math.abs(dx) / stepSize));
          ctx.fillStyle = mainColor;
          for (let s = 1; s <= numSteps; s++) {
            const xp = x0 + dx * (s / numSteps);
            const ch = chars[Math.floor(Math.random() * chars.length)];
            ctx.fillText(ch, xp, ghost.y);
          }
          if (ghost.frame >= ghost.totalFrames) ghosts.splice(g, 1);
        }
      }

      if (lensCtx) {
        lensCtx.clearRect(0, 0, lens.width, lens.height);
        lensCtx.drawImage(canvas, 0, 0);
      }
    }

    initMatrix();
    window.addEventListener('resize', initMatrix);
    rafId = requestAnimationFrame(drawMatrix);

    /* Cursor lens tracking with smooth lerp follow */
    if (lens) {
      let targetX = -200, targetY = -200;
      let currentX = -200, currentY = -200;
      let cursorActive = false;
      const LERP = 0.22;

      window.addEventListener('mousemove', e => {
        targetX = e.clientX;
        targetY = e.clientY;
        if (!cursorActive) { cursorActive = true; requestAnimationFrame(lerpLoop); }
      });
      window.addEventListener('mouseleave', () => {
        targetX = -200; targetY = -200;
      });

      function lerpLoop() {
        currentX += (targetX - currentX) * LERP;
        currentY += (targetY - currentY) * LERP;
        lens.style.setProperty('--cx', currentX.toFixed(1) + 'px');
        lens.style.setProperty('--cy', currentY.toFixed(1) + 'px');
        if (Math.abs(targetX - currentX) > 0.5 || Math.abs(targetY - currentY) > 0.5) {
          requestAnimationFrame(lerpLoop);
        } else {
          cursorActive = false;
        }
      }
    }

    /* Cursor halo follow */
    const halo = document.getElementById('cursor-halo');
    if (halo) {
      const HALO_HALF = 100;
      let haloRAF = null, hx = 0, hy = 0;
      window.addEventListener('mousemove', e => {
        hx = e.clientX; hy = e.clientY;
        halo.style.opacity = '1';
        if (!haloRAF) {
          haloRAF = requestAnimationFrame(() => {
            halo.style.transform = `translate3d(${hx - HALO_HALF}px, ${hy - HALO_HALF}px, 0)`;
            haloRAF = null;
          });
        }
      });
      window.addEventListener('mouseleave', () => { halo.style.opacity = '0'; });
    }

    /* Click shockwave */
    window.addEventListener('click', e => {
      const wave = document.createElement('div');
      wave.className = 'shockwave';
      wave.style.left = e.clientX + 'px';
      wave.style.top = e.clientY + 'px';
      document.body.appendChild(wave);
      wave.addEventListener('animationend', () => wave.remove(), { once: true });
    });

    window.addEventListener('beforeunload', () => {
      if (rafId) cancelAnimationFrame(rafId);
    });
  })();
</script>
