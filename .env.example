# Repo-root environment file template.
# Copy to .env and fill real values. .env is gitignored.

# Vapi assistant ID for the voice_agent assistant. Used by vapi-evals scripts
# to bind the test suite to the right assistant.
# Source: Vapi Dashboard -> Assistants -> voice_agent -> ID (URL bar).
# VAPI_ASSISTANT_ID=

# Vapi private API key (Vapi Dashboard -> Profile -> API Keys -> private).
# Optional here - kept as a Windows User-level env var by default.
# Uncomment + fill if you prefer co-locating it with VAPI_ASSISTANT_ID.
# VAPI_PRIVATE_TOKEN=
